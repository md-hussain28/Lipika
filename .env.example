# Copy to .env and fill in values for your environment.

ENVIRONMENT=development

# Database — PostgreSQL recommended for all environments.
# Example: postgresql+asyncpg://user:password@localhost:5432/lipika
# Run `make migrate` (or `uv run alembic upgrade head`) before starting the app.
DATABASE_URL=postgresql+asyncpg://msh@localhost:5432/lipika
DATABASE_ECHO=false

# Redis — leave empty to disable. Enables shared rate limiting + caching.
REDIS_URL=

# OpenAI — leave empty to disable AI endpoints.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# CORS — comma-separated frontend URLs
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Trusted hosts — comma-separated
ALLOWED_HOSTS=localhost,127.0.0.1

RATE_LIMIT_PER_MINUTE=60
METRICS_ENABLED=true
